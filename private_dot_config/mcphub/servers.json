{
  "mcpServers": {
    "AZ": {
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "command": "npx",
      "env": {
        "AZURE_CLIENT_ID": "kbuley@catmktg.com",
        "AZURE_TENANT_ID": "2eddc39c-2996-4c2a-ab97-f767c39ea155"
      }
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/kbuley/Projects/"
      ],
      "autoApprove": [
        "get_file_info",
        "list_allowed_directories",
        "list_directory",
        "list_directory_with_sizes",
        "read_file",
        "read_media_file",
        "read_multiple_files",
        "read_text_file",
        "search_files",
        "directory_tree"
      ],
      "command": "npx"
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "disabled": false
    },
    "neovim": {
      "autoApprove": [
        "execute_lua",
        "execute_command",
        "read_file",
        "move_item",
        "read_multiple_files",
        "delete_items",
        "find_files",
        "list_directory",
        "write_file",
        "edit_file"
      ],
      "disabled": false
    }
  }
}
