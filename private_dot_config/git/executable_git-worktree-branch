#!/usr/bin/env bash
set -euo pipefail

usage() {
	echo "Usage: $0 <branch-name> [parent-branch]"
	echo "  branch-name    Name of the new branch and worktree to create"
	echo "  parent-branch  Parent branch to base the new branch on (default: main)"
	echo ""
	echo "Examples:"
	echo "  $0 my-feature develop"
	echo "  $0 my-feature"
	exit 1
}

find_bare_repo_root() {
	local current_dir="$PWD"
	while [[ "$current_dir" != "/" ]]; do
		if [[ -d "$current_dir/.bare" ]] && git -C "$current_dir/.bare" rev-parse --git-dir &>/dev/null; then
			echo "$current_dir"
			return 0
		fi
		current_dir="$(dirname "$current_dir")"
	done
	echo "Error: Not in a bare worktree repository" >&2
	exit 1
}

[[ $# -eq 0 ]] || [[ $# -gt 2 ]] && usage

branch_name="$1"
parent_branch="${2:-main}"
worktree_name="${branch_name//\//-}"

[[ -z "$branch_name" ]] && {
	echo "Error: Branch name cannot be empty" >&2
	exit 1
}

echo "Searching for bare repository root..."
git_root="$(find_bare_repo_root)"
echo "Found bare repository root at: $git_root"

bare="$git_root/.bare"

if git -C "$bare" show-ref --verify --quiet "refs/heads/$branch_name"; then
	echo "Error: Branch '$branch_name' already exists" >&2
	exit 1
fi

worktree_path="$git_root/$worktree_name"
if [[ -e "$worktree_path" ]]; then
	echo "Error: Directory '$worktree_path' already exists" >&2
	exit 1
fi

if ! git -C "$bare" show-ref --verify --quiet "refs/heads/$parent_branch" &&
	! git -C "$bare" show-ref --verify --quiet "refs/remotes/origin/$parent_branch"; then
	echo "Error: Parent branch '$parent_branch' does not exist" >&2
	exit 1
fi

echo "Creating branch '$branch_name' from '$parent_branch'..."
git -C "$bare" worktree add -b "$branch_name" "$worktree_path" "$parent_branch"

echo "Created branch '$branch_name' at: $worktree_path"
