# Font
font-family = FiraCode Nerd Font
font-size = 12

# Theme
theme = Catppuccin Mocha

# Scrollback
scrollback-limit = 50000

# Dim inactive splits
unfocused-split-opacity = 0.3

# Shell integration
shell-integration = zsh

# Keybindings - leader is ctrl+b
keybind = ctrl+b=unbind

# Unbind defaults we're replacing
keybind = ctrl+shift+tab=unbind
keybind = ctrl+tab=unbind

# Clear screen (leader+ctrl+l)
keybind = ctrl+b>ctrl+l=clear_screen

# Copy mode (leader+[)
keybind = ctrl+b>[=start_search

# Zoom pane (leader+z)
keybind = ctrl+b>z=toggle_split_zoom

# Tabs
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>n=next_tab
keybind = ctrl+b>p=previous_tab
keybind = ctrl+b>k=close_surface
keybind = ctrl+b>comma=prompt_tab_title

# Splits
keybind = ctrl+b>shift+backslash=new_split:right
keybind = ctrl+b>shift+minus=new_split:down

# Pane navigation
keybind = ctrl+shift+arrow_left=goto_split:left
keybind = ctrl+shift+arrow_right=goto_split:right
keybind = ctrl+shift+arrow_up=goto_split:up
keybind = ctrl+shift+arrow_down=goto_split:down

# Pane resize
keybind = ctrl+alt+shift+arrow_left=resize_split:left,10
keybind = ctrl+alt+shift+arrow_right=resize_split:right,10
keybind = ctrl+alt+shift+arrow_up=resize_split:up,10
keybind = ctrl+alt+shift+arrow_down=resize_split:down,10

# Clipboard
keybind = ctrl+b>]=paste_from_clipboard
keybind = ctrl+b>y=copy_to_clipboard

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size

# Tab navigation by number (ctrl+alt+N to match wezterm config)
keybind = ctrl+alt+1=goto_tab:1
keybind = ctrl+alt+2=goto_tab:2
keybind = ctrl+alt+3=goto_tab:3
keybind = ctrl+alt+4=goto_tab:4
keybind = ctrl+alt+5=goto_tab:5
keybind = ctrl+alt+6=goto_tab:6
keybind = ctrl+alt+7=goto_tab:7
keybind = ctrl+alt+8=goto_tab:8

# Move tabs
keybind = ctrl+alt+shift+arrow_left=move_tab:-1
keybind = ctrl+alt+shift+arrow_right=move_tab:1

# Shift+Enter for Claude Code
keybind = shift+enter=text:\x1b\r
