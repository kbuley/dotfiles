#!/usr/bin/env bash
set -euo pipefail

url=$1
basename=${url##*/}
name=${2:-${basename%.*}}

mkdir "$name"
cd "$name"

git clone --bare "$url" .bare

# Fix fetch refspecs (bare clones omit this)
git -C .bare config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
git -C .bare config --add remote.origin.fetch "refs/notes/*:refs/notes/*"
git -C .bare config --add remote.origin.fetch "refs/tags/*:refs/tags/*"
git -C .bare config --add remote.origin.push "refs/notes/*:refs/notes/*"
git -C .bare config --add remote.origin.push "refs/tags/*:refs/tags/*"
git -C .bare config notes.displayRef "refs/notes/*"
git -C .bare config notes.rewriteRef "refs/notes/*"

git -C .bare fetch origin

git -C .bare for-each-ref --format='%(refname:short)' 'refs/remotes/origin/' |
	while read -r remote_branch; do
		branch_name="${remote_branch#origin/}"
		[[ "$branch_name" == "HEAD" ]] && continue
		[[ "$branch_name" == "origin" ]] && continue

		# Flatten slashes to avoid nested directories
		worktree_name="${branch_name//\//-}"

		git -C .bare worktree add "../$worktree_name" "$branch_name"
		git -C .bare branch --set-upstream-to="origin/$branch_name" "$branch_name"
		echo "Worktree added: $worktree_name -> $branch_name"
	done
