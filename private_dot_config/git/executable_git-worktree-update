#!/usr/bin/env bash
set -euo pipefail

# Find bare repo root
find_bare_repo_root() {
	local current_dir="$PWD"
	while [[ "$current_dir" != "/" ]]; do
		if [[ -d "$current_dir/.bare" ]] && git -C "$current_dir/.bare" rev-parse --git-dir &>/dev/null; then
			echo "$current_dir"
			return 0
		fi
		current_dir="$(dirname "$current_dir")"
	done
	echo "Error: Not in a bare worktree repository" >&2
	exit 1
}

git_root="$(find_bare_repo_root)"
bare="$git_root/.bare"
echo "Found bare repository root at: $git_root"

# Fetch everything, prune stale remote refs
echo "Fetching origin..."
git -C "$bare" fetch --prune --tags --force origin

# Add worktrees for any new remote branches
echo "Checking for new remote branches..."
git -C "$bare" for-each-ref --format='%(refname:short)' 'refs/remotes/origin/' |
	while read -r remote_branch; do
		branch_name="${remote_branch#origin/}"
		[[ "$branch_name" == "HEAD" ]] && continue
		[[ "$branch_name" == "origin" ]] && continue

		worktree_name="${branch_name//\//-}"
		worktree_path="$git_root/$worktree_name"

		if [[ ! -d "$worktree_path" ]]; then
			echo "Adding worktree: $worktree_name"
			git -C "$bare" worktree add "$worktree_path" "$branch_name"
		fi
	done

# Sync or remove existing worktrees
echo "Syncing worktrees..."
git -C "$bare" worktree list --porcelain | awk '/^worktree/ && !/\.bare$/ {print $2}' |
	while read -r worktree_path; do
		branch_name=$(git -C "$worktree_path" branch --show-current 2>/dev/null || true)

		echo -n "  $worktree_path: "

		# Skip detached HEADs
		if [[ -z "$branch_name" ]]; then
			echo "skipped (detached HEAD)"
			continue
		fi

		# If remote branch no longer exists (already pruned), clean up
		if ! git -C "$bare" show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
			if [[ -z $(git -C "$worktree_path" status --porcelain) ]]; then
				echo "removing (no remote, clean)"
				git -C "$bare" worktree remove "$worktree_path"
				git -C "$bare" branch -D "$branch_name"
			else
				echo ""
				echo "  WARNING: no remote branch but worktree is dirty, skipping: $worktree_path"
			fi
			continue
		fi

		# No upstream means new local branch not yet pushed, skip
		if ! git -C "$worktree_path" rev-parse "@{u}" &>/dev/null; then
			echo "skipped (no upstream, assuming new branch)"
			continue
		fi

		local_ref=$(git -C "$worktree_path" rev-parse "@")
		remote_ref=$(git -C "$worktree_path" rev-parse "@{u}")

		if [[ "$local_ref" == "$remote_ref" ]]; then
			echo "up to date"
			continue
		fi

		is_dirty=$(git -C "$worktree_path" status --porcelain)

		if [[ -n "$is_dirty" ]]; then
			echo "stashing, rebasing, popping..."
			git -C "$worktree_path" stash push -m "auto-stash by sync script"
			if git -C "$worktree_path" pull --rebase; then
				if ! git -C "$worktree_path" stash pop; then
					echo "  WARNING: stash pop conflicted in $worktree_path"
					echo "  Stash entry preserved. Resolve conflicts manually."
				fi
			else
				echo "  WARNING: rebase failed in $worktree_path"
				echo "  Aborting rebase and restoring stash..."
				git -C "$worktree_path" rebase --abort
				git -C "$worktree_path" stash pop
			fi
		else
			echo "rebasing..."
			git -C "$worktree_path" pull --rebase
		fi
	done

echo "Done."
